{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "voidBlack": "#050508",
    "voidDark": "#0a0a12",
    "voidBlue": "#1e3a5f",
    "voidNavy": "#0d1b2a",
    "voidCyan": "#00d4ff",
    "voidElectric": "#7df9ff",
    "voidViolet": "#8b5cf6",
    "voidMagenta": "#d946ef",
    "voidRose": "#fb7185",
    "voidGray": "#1e293b",
    "voidMuted": "#64748b"
  },
  "theme": {
    "primary": { "dark": "voidCyan", "light": "voidViolet" },
    "secondary": { "dark": "voidMagenta", "light": "voidRose" },
    "accent": { "dark": "voidElectric", "light": "voidCyan" },
    "error": { "dark": "voidRose", "light": "#e11d48" },
    "warning": { "dark": "#fbbf24", "light": "#f59e0b" },
    "success": { "dark": "voidCyan", "light": "#10b981" },
    "info": { "dark": "voidElectric", "light": "voidViolet" },
    "text": { "dark": "#e2e8f0", "light": "voidDark" },
    "textMuted": { "dark": "voidMuted", "light": "voidGray" },
    "background": { "dark": "voidBlack", "light": "#f1f5f9" },
    "backgroundPanel": { "dark": "voidDark", "light": "#e2e8f0" },
    "backgroundElement": { "dark": "voidNavy", "light": "#cbd5e1" },
    "border": { "dark": "voidGray", "light": "#94a3b8" },
    "borderActive": { "dark": "voidCyan", "light": "voidViolet" },
    "borderSubtle": { "dark": "#1e293b", "light": "#cbd5e1" },
    "diffAdded": { "dark": "voidCyan", "light": "#10b981" },
    "diffRemoved": { "dark": "voidRose", "light": "#e11d48" },
    "diffContext": { "dark": "voidMuted", "light": "voidGray" },
    "diffHunkHeader": { "dark": "voidGray", "light": "#94a3b8" },
    "diffHighlightAdded": { "dark": "voidCyan", "light": "#10b981" },
    "diffHighlightRemoved": { "dark": "voidRose", "light": "#e11d48" },
    "diffAddedBg": { "dark": "#0a1f2a", "light": "#d1fae5" },
    "diffRemovedBg": { "dark": "#1f0a10", "light": "#ffe4e6" },
    "diffContextBg": { "dark": "voidDark", "light": "#e2e8f0" },
    "diffLineNumber": { "dark": "voidGray", "light": "#64748b" },
    "diffAddedLineNumberBg": { "dark": "#0a1f2a", "light": "#d1fae5" },
    "diffRemovedLineNumberBg": { "dark": "#1f0a10", "light": "#ffe4e6" },
    "markdownText": { "dark": "#e2e8f0", "light": "voidDark" },
    "markdownHeading": { "dark": "voidCyan", "light": "voidViolet" },
    "markdownLink": { "dark": "voidElectric", "light": "voidMagenta" },
    "markdownLinkText": { "dark": "voidCyan", "light": "voidRose" },
    "markdownCode": { "dark": "voidElectric", "light": "voidCyan" },
    "markdownBlockQuote": { "dark": "voidGray", "light": "#64748b" },
    "markdownEmph": { "dark": "voidMagenta", "light": "voidRose" },
    "markdownStrong": { "dark": "voidCyan", "light": "voidViolet" },
    "markdownHorizontalRule": { "dark": "voidGray", "light": "#94a3b8" },
    "markdownListItem": { "dark": "voidCyan", "light": "voidViolet" },
    "markdownListEnumeration": { "dark": "voidElectric", "light": "voidMagenta" },
    "markdownImage": { "dark": "voidElectric", "light": "voidMagenta" },
    "markdownImageText": { "dark": "voidCyan", "light": "voidRose" },
    "markdownCodeBlock": { "dark": "#e2e8f0", "light": "voidDark" },
    "syntaxComment": { "dark": "voidMuted", "light": "#64748b" },
    "syntaxKeyword": { "dark": "voidMagenta", "light": "voidRose" },
    "syntaxFunction": { "dark": "voidElectric", "light": "voidCyan" },
    "syntaxVariable": { "dark": "voidCyan", "light": "voidViolet" },
    "syntaxString": { "dark": "voidElectric", "light": "voidCyan" },
    "syntaxNumber": { "dark": "#fbbf24", "light": "voidMagenta" },
    "syntaxType": { "dark": "voidElectric", "light": "voidCyan" },
    "syntaxOperator": { "dark": "voidMagenta", "light": "voidRose" },
    "syntaxPunctuation": { "dark": "voidMuted", "light": "#64748b" }
