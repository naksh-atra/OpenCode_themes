{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "staticBlack": "#0c0c0c",
    "staticDark": "#1c1c1c",
    "staticWhite": "#e8e8e8",
    "staticLight": "#d0d0d0",
    "staticNoise": "#888888",
    "staticGray": "#555555",
    "staticDim": "#333333",
    "staticSignal": "#ff4444",
    "staticScan": "#44ff44",
    "staticBlue": "#4444ff"
  },
  "theme": {
    "primary": { "dark": "staticSignal", "light": "staticDark" },
    "secondary": { "dark": "staticScan", "light": "staticGray" },
    "accent": { "dark": "staticBlue", "light": "staticSignal" },
    "error": { "dark": "#ff2222", "light": "#cc0000" },
    "warning": { "dark": "#ffaa00", "light": "#cc7700" },
    "success": { "dark": "staticScan", "light": "#00aa00" },
    "info": { "dark": "staticBlue", "light": "staticGray" },
    "text": { "dark": "staticWhite", "light": "staticBlack" },
    "textMuted": { "dark": "staticNoise", "light": "staticGray" },
    "background": { "dark": "staticBlack", "light": "staticWhite" },
    "backgroundPanel": { "dark": "staticDark", "light": "staticLight" },
    "backgroundElement": { "dark": "staticDim", "light": "#c8c8c8" },
    "border": { "dark": "staticGray", "light": "staticNoise" },
    "borderActive": { "dark": "staticSignal", "light": "staticDark" },
    "borderSubtle": { "dark": "staticDim", "light": "#b0b0b0" },
    "diffAdded": { "dark": "staticScan", "light": "#00aa00" },
    "diffRemoved": { "dark": "#ff2222", "light": "#cc0000" },
    "diffContext": { "dark": "staticNoise", "light": "staticGray" },
    "diffHunkHeader": { "dark": "staticGray", "light": "staticNoise" },
    "diffHighlightAdded": { "dark": "staticScan", "light": "#00aa00" },
    "diffHighlightRemoved": { "dark": "#ff2222", "light": "#cc0000" },
    "diffAddedBg": { "dark": "#0a1a0a", "light": "#e0ffe0" },
    "diffRemovedBg": { "dark": "#1a0a0a", "light": "#ffe0e0" },
    "diffContextBg": { "dark": "staticDark", "light": "staticLight" },
    "diffLineNumber": { "dark": "staticGray", "light": "staticNoise" },
    "diffAddedLineNumberBg": { "dark": "#0a1a0a", "light": "#e0ffe0" },
    "diffRemovedLineNumberBg": { "dark": "#1a0a0a", "light": "#ffe0e0" },
    "markdownText": { "dark": "staticWhite", "light": "staticBlack" },
    "markdownHeading": { "dark": "staticSignal", "light": "staticDark" },
    "markdownLink": { "dark": "staticBlue", "light": "staticGray" },
    "markdownLinkText": { "dark": "staticScan", "light": "staticSignal" },
    "markdownCode": { "dark": "staticScan", "light": "staticDark" },
    "markdownBlockQuote": { "dark": "staticNoise", "light": "staticGray" },
    "markdownEmph": { "dark": "#ffaa00", "light": "#cc7700" },
    "markdownStrong": { "dark": "staticSignal", "light": "staticDark" },
    "markdownHorizontalRule": { "dark": "staticGray", "light": "staticNoise" },
    "markdownListItem": { "dark": "staticSignal", "light": "staticDark" },
    "markdownListEnumeration": { "dark": "staticScan", "light": "staticGray" },
    "markdownImage": { "dark": "staticBlue", "light": "staticGray" },
    "markdownImageText": { "dark": "staticScan", "light": "staticSignal" },
    "markdownCodeBlock": { "dark": "staticWhite", "light": "staticBlack" },
    "syntaxComment": { "dark": "staticNoise", "light": "staticGray" },
    "syntaxKeyword": { "dark": "staticSignal", "light": "#cc0000" },
    "syntaxFunction": { "dark": "staticBlue", "light": "staticGray" },
    "syntaxVariable": { "dark": "staticScan", "light": "staticSignal" },
    "syntaxString": { "dark": "staticScan", "light": "staticDark" },
    "syntaxNumber": { "dark": "#ffaa00", "light": "staticSignal" },
    "syntaxType": { "dark": "staticBlue", "light": "staticGray" },
    "syntaxOperator": { "dark": "staticSignal", "light": "#cc0000" },
    "syntaxPunctuation": { "dark": "staticNoise", "light": "staticGray" }
  }
}