{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "flareBlack": "#0a0805",
    "flareDark": "#1a1008",
    "flareCore": "#ff6600",
    "flareBright": "#ff9933",
    "flareYellow": "#ffcc00",
    "flareWhite": "#ffeecc",
    "flareOrange": "#ff4400",
    "flareRed": "#cc2200",
    "flareMuted": "#996633",
    "flareGray": "#4d3319",
    "flarePlasma": "#ff3300"
  },
  "theme": {
    "primary": { "dark": "flareCore", "light": "flareOrange" },
    "secondary": { "dark": "flareBright", "light": "flareRed" },
    "accent": { "dark": "flareYellow", "light": "flareBright" },
    "error": { "dark": "flareRed", "light": "#aa0000" },
    "warning": { "dark": "flareYellow", "light": "flareOrange" },
    "success": { "dark": "#ffaa33", "light": "#cc6600" },
    "info": { "dark": "flareBright", "light": "flareRed" },
    "text": { "dark": "flareWhite", "light": "flareDark" },
    "textMuted": { "dark": "flareMuted", "light": "flareGray" },
    "background": { "dark": "flareBlack", "light": "flareWhite" },
    "backgroundPanel": { "dark": "#1f1408", "light": "#fff5e6" },
    "backgroundElement": { "dark": "#2a1a0a", "light": "#ffe8cc" },
    "border": { "dark": "flareGray", "light": "flareMuted" },
    "borderActive": { "dark": "flareCore", "light": "flareOrange" },
    "borderSubtle": { "dark": "#332010", "light": "#ffd9b3" },
    "diffAdded": { "dark": "#ffaa33", "light": "#cc6600" },
    "diffRemoved": { "dark": "flareRed", "light": "#aa0000" },
    "diffContext": { "dark": "flareMuted", "light": "flareGray" },
    "diffHunkHeader": { "dark": "flareGray", "light": "flareMuted" },
    "diffHighlightAdded": { "dark": "#ffaa33", "light": "#cc6600" },
    "diffHighlightRemoved": { "dark": "flareRed", "light": "#aa0000" },
    "diffAddedBg": { "dark": "#1f1405", "light": "#fff0e0" },
    "diffRemovedBg": { "dark": "#1f0a05", "light": "#ffe0e0" },
    "diffContextBg": { "dark": "#1f1408", "light": "#fff5e6" },
    "diffLineNumber": { "dark": "flareGray", "light": "flareMuted" },
    "diffAddedLineNumberBg": { "dark": "#1f1405", "light": "#fff0e0" },
    "diffRemovedLineNumberBg": { "dark": "#1f0a05", "light": "#ffe0e0" },
    "markdownText": { "dark": "flareWhite", "light": "flareDark" },
    "markdownHeading": { "dark": "flareCore", "light": "flareOrange" },
    "markdownLink": { "dark": "flareBright", "light": "flareRed" },
    "markdownLinkText": { "dark": "flareYellow", "light": "flareOrange" },
    "markdownCode": { "dark": "flareYellow", "light": "flareCore" },
    "markdownBlockQuote": { "dark": "flareMuted", "light": "flareGray" },
    "markdownEmph": { "dark": "flareBright", "light": "flareOrange" },
    "markdownStrong": { "dark": "flareYellow", "light": "flareCore" },
    "markdownHorizontalRule": { "dark": "flareGray", "light": "flareMuted" },
    "markdownListItem": { "dark": "flareCore", "light": "flareOrange" },
    "markdownListEnumeration": { "dark": "flareYellow", "light": "flareRed" },
    "markdownImage": { "dark": "flareBright", "light": "flareRed" },
    "markdownImageText": { "dark": "flareYellow", "light": "flareOrange" },
    "markdownCodeBlock": { "dark": "flareWhite", "light": "flareDark" },
    "syntaxComment": { "dark": "flareMuted", "light": "flareGray" },
    "syntaxKeyword": { "dark": "flareOrange", "light": "flareRed" },
    "syntaxFunction": { "dark": "flareYellow", "light": "flareCore" },
    "syntaxVariable": { "dark": "flareYellow", "light": "flareOrange" },
    "syntaxString": { "dark": "flareYellow", "light": "flareCore" },
    "syntaxNumber": { "dark": "flareBright", "light": "flareOrange" },
    "syntaxType": { "dark": "flareYellow", "light": "flareCore" },
    "syntaxOperator": { "dark": "flareOrange", "light": "flareRed" },
    "syntaxPunctuation": { "dark": "flareMuted", "light": "flareGray" }
  }
}