{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "oceanAbyss": "#020810",
    "oceanDeep": "#041828",
    "oceanMid": "#083656",
    "oceanLight": "#0c4a7c",
    "oceanSurface": "#1a6b9c",
    "oceanFoam": "#a8d4e6",
    "oceanWhite": "#e8f4f8",
    "oceanCyan": "#00d4ff",
    "oceanTeal": "#0088aa",
    "oceanMuted": "#4a6a7a",
    "oceanGray": "#2a3a4a"
  },
  "theme": {
    "primary": { "dark": "oceanCyan", "light": "oceanTeal" },
    "secondary": { "dark": "oceanTeal", "light": "oceanLight" },
    "accent": { "dark": "oceanFoam", "light": "oceanCyan" },
    "error": { "dark": "#ff6b6b", "light": "#c0392b" },
    "warning": { "dark": "#f4a742", "light": "#d68910" },
    "success": { "dark": "oceanCyan", "light": "#1e8449" },
    "info": { "dark": "oceanTeal", "light": "oceanLight" },
    "text": { "dark": "oceanFoam", "light": "oceanAbyss" },
    "textMuted": { "dark": "oceanMuted", "light": "oceanGray" },
    "background": { "dark": "oceanAbyss", "light": "oceanWhite" },
    "backgroundPanel": { "dark": "oceanDeep", "light": "#d4e8ef" },
    "backgroundElement": { "dark": "#052a3d", "light": "#c2dce6" },
    "border": { "dark": "oceanGray", "light": "oceanMuted" },
    "borderActive": { "dark": "oceanCyan", "light": "oceanTeal" },
    "borderSubtle": { "dark": "#063040", "light": "#b0cad8" },
    "diffAdded": { "dark": "oceanCyan", "light": "#1e8449" },
    "diffRemoved": { "dark": "#ff6b6b", "light": "#c0392b" },
    "diffContext": { "dark": "oceanMuted", "light": "oceanGray" },
    "diffHunkHeader": { "dark": "oceanGray", "light": "oceanMuted" },
    "diffHighlightAdded": { "dark": "oceanCyan", "light": "#1e8449" },
    "diffHighlightRemoved": { "dark": "#ff6b6b", "light": "#c0392b" },
    "diffAddedBg": { "dark": "#031520", "light": "#e0f5eb" },
    "diffRemovedBg": { "dark": "#150a10", "light": "#f5e0e0" },
    "diffContextBg": { "dark": "oceanDeep", "light": "#d4e8ef" },
    "diffLineNumber": { "dark": "oceanGray", "light": "oceanMuted" },
    "diffAddedLineNumberBg": { "dark": "#031520", "light": "#e0f5eb" },
    "diffRemovedLineNumberBg": { "dark": "#150a10", "light": "#f5e0e0" },
    "markdownText": { "dark": "oceanFoam", "light": "oceanAbyss" },
    "markdownHeading": { "dark": "oceanCyan", "light": "oceanTeal" },
    "markdownLink": { "dark": "oceanTeal", "light": "oceanLight" },
    "markdownLinkText": { "dark": "oceanFoam", "light": "oceanCyan" },
    "markdownCode": { "dark": "oceanFoam", "light": "oceanTeal" },
    "markdownBlockQuote": { "dark": "oceanMuted", "light": "oceanGray" },
    "markdownEmph": { "dark": "#f4a742", "light": "#d68910" },
    "markdownStrong": { "dark": "oceanCyan", "light": "oceanTeal" },
    "markdownHorizontalRule": { "dark": "oceanGray", "light": "oceanMuted" },
    "markdownListItem": { "dark": "oceanCyan", "light": "oceanTeal" },
    "markdownListEnumeration": { "dark": "oceanFoam", "light": "oceanLight" },
    "markdownImage": { "dark": "oceanTeal", "light": "oceanLight" },
    "markdownImageText": { "dark": "oceanFoam", "light": "oceanCyan" },
    "markdownCodeBlock": { "dark": "oceanFoam", "light": "oceanAbyss" },
    "syntaxComment": { "dark": "oceanMuted", "light": "oceanGray" },
    "syntaxKeyword": { "dark": "oceanCyan", "light": "oceanLight" },
    "syntaxFunction": { "dark": "oceanFoam", "light": "oceanTeal" },
    "syntaxVariable": { "dark": "oceanFoam", "light": "oceanCyan" },
    "syntaxString": { "dark": "oceanFoam", "light": "oceanTeal" },
    "syntaxNumber": { "dark": "#f4a742", "light": "oceanLight" },
    "syntaxType": { "dark": "oceanFoam", "light": "oceanTeal" },
    "syntaxOperator": { "dark": "oceanCyan", "light": "oceanLight" },
    "syntaxPunctuation": { "dark": "oceanMuted", "light": "oceanGray" }
  }
}