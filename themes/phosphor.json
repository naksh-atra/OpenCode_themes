{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "phosBlack": "#0d0d0d",
    "phosDark": "#1a1a1a",
    "phosGreen": "#33ff33",
    "phosBright": "#00ff00",
    "phosDim": "#004d00",
    "phosMid": "#006600",
    "phosScan": "#0d1a0d",
    "phosGray": "#333333",
    "phosLight": "#4d4d4d",
    "phosAmber": "#ffb300",
    "phosRed": "#ff3333"
  },
  "theme": {
    "primary": { "dark": "phosGreen", "light": "phosAmber" },
    "secondary": { "dark": "phosBright", "light": "phosGreen" },
    "accent": { "dark": "phosBright", "light": "phosAmber" },
    "error": { "dark": "phosRed", "light": "#cc0000" },
    "warning": { "dark": "phosAmber", "light": "#cc6600" },
    "success": { "dark": "phosGreen", "light": "#00cc00" },
    "info": { "dark": "phosBright", "light": "phosGreen" },
    "text": { "dark": "phosGreen", "light": "#1a1a00" },
    "textMuted": { "dark": "phosDim", "light": "#4d4d00" },
    "background": { "dark": "phosBlack", "light": "#f0f0e8" },
    "backgroundPanel": { "dark": "#111111", "light": "#e8e8e0" },
    "backgroundElement": { "dark": "#151515", "light": "#d8d8d0" },
    "border": { "dark": "phosGray", "light": "#666600" },
    "borderActive": { "dark": "phosGreen", "light": "phosAmber" },
    "borderSubtle": { "dark": "#1f1f1f", "light": "#b8b8a8" },
    "diffAdded": { "dark": "phosGreen", "light": "#00cc00" },
    "diffRemoved": { "dark": "phosRed", "light": "#cc0000" },
    "diffContext": { "dark": "phosDim", "light": "#4d4d00" },
    "diffHunkHeader": { "dark": "phosGray", "light": "#666600" },
    "diffHighlightAdded": { "dark": "phosGreen", "light": "#00cc00" },
    "diffHighlightRemoved": { "dark": "phosRed", "light": "#cc0000" },
    "diffAddedBg": { "dark": "#0a1a0a", "light": "#e0ffe0" },
    "diffRemovedBg": { "dark": "#1a0a0a", "light": "#ffe0e0" },
    "diffContextBg": { "dark": "#111111", "light": "#e8e8e0" },
    "diffLineNumber": { "dark": "phosGray", "light": "#666600" },
    "diffAddedLineNumberBg": { "dark": "#0a1a0a", "light": "#e0ffe0" },
    "diffRemovedLineNumberBg": { "dark": "#1a0a0a", "light": "#ffe0e0" },
    "markdownText": { "dark": "phosGreen", "light": "#1a1a00" },
    "markdownHeading": { "dark": "phosBright", "light": "phosAmber" },
    "markdownLink": { "dark": "phosBright", "light": "phosGreen" },
    "markdownLinkText": { "dark": "phosGreen", "light": "phosAmber" },
    "markdownCode": { "dark": "phosBright", "light": "phosGreen" },
    "markdownBlockQuote": { "dark": "phosDim", "light": "#4d4d00" },
    "markdownEmph": { "dark": "phosAmber", "light": "#cc6600" },
    "markdownStrong": { "dark": "phosBright", "light": "phosAmber" },
    "markdownHorizontalRule": { "dark": "phosGray", "light": "#666600" },
    "markdownListItem": { "dark": "phosBright", "light": "phosAmber" },
    "markdownListEnumeration": { "dark": "phosGreen", "light": "phosGreen" },
    "markdownImage": { "dark": "phosBright", "light": "phosGreen" },
    "markdownImageText": { "dark": "phosGreen", "light": "phosAmber" },
    "markdownCodeBlock": { "dark": "phosGreen", "light": "#1a1a00" },
    "syntaxComment": { "dark": "phosDim", "light": "#4d4d00" },
    "syntaxKeyword": { "dark": "phosAmber", "light": "#cc6600" },
    "syntaxFunction": { "dark": "phosBright", "light": "phosGreen" },
    "syntaxVariable": { "dark": "phosGreen", "light": "phosAmber" },
    "syntaxString": { "dark": "phosBright", "light": "phosGreen" },
    "syntaxNumber": { "dark": "phosAmber", "light": "phosAmber" },
    "syntaxType": { "dark": "phosBright", "light": "phosGreen" },
    "syntaxOperator": { "dark": "phosAmber", "light": "#cc6600" },
    "syntaxPunctuation": { "dark": "phosDim", "light": "#4d4d00" }
  }
}